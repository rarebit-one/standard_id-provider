<% content_for :title, "Sign Up" %>

<div class="container">
  <h1>Create Account</h1>

  <% if flash[:alert] %>
    <div class="alert alert-error">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if flash[:notice] %>
    <div class="alert alert-success">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- Social Signup Options -->
  <% if StandardId.config.google_client_id.present? %>
    <%= form_with url: signup_path, method: :post, local: true do |form| %>
      <%= form.hidden_field :connection, value: "google-oauth2" %>
      <%= form.hidden_field :redirect_uri, value: @redirect_uri %>
      <%= form.submit "Continue with Google", class: "btn btn-google btn-social" %>
    <% end %>
  <% end %>

  <% if StandardId.config.apple_client_id.present? %>
    <%= form_with url: signup_path, method: :post, local: true do |form| %>
      <%= form.hidden_field :connection, value: "apple" %>
      <%= form.hidden_field :redirect_uri, value: @redirect_uri %>
      <%= form.submit "Continue with Apple", class: "btn btn-apple btn-social" %>
    <% end %>
  <% end %>

  <% if StandardId.config.google_client_id.present? || StandardId.config.apple_client_id.present? %>
    <div class="divider">
      <span>or</span>
    </div>
  <% end %>

  <!-- Email/Password Signup -->
  <%= form_with url: signup_path, method: :post, local: true do |form| %>
    <%= form.hidden_field :redirect_uri, value: @redirect_uri %>

    <div class="form-group">
      <%= form.label :email, "Email" %>
      <%= form.email_field "signup[email]", required: true, autofocus: true %>
    </div>

    <div class="form-group">
      <%= form.label :password, "Password" %>
      <%= form.password_field "signup[password]", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :password_confirmation, "Confirm Password" %>
      <%= form.password_field "signup[password_confirmation]", required: true %>
    </div>

    <%= form.submit "Create Account", class: "btn" %>
  <% end %>

  <div class="text-center mt-3">
    Already have an account? <%= link_to "Sign in", login_path(redirect_uri: @redirect_uri) %>
  </div>
</div>
