<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-base font-semibold text-gray-900 dark:text-white">Access Tokens</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">Monitor and manage OAuth access tokens.</p>
    </div>
  </div>

  <div class="mt-8">
    <% if @message %>
      <div class="rounded-md bg-yellow-50 p-4 dark:bg-yellow-900/20">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="size-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-200">Token Management Unavailable</h3>
            <div class="mt-2 text-sm text-yellow-700 dark:text-yellow-300">
              <p><%= @message %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @tokens.any? %>
      <div class="flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
            <table class="relative min-w-full divide-y divide-gray-300 dark:divide-white/15">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-0 dark:text-white">Token</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Account</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Client</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Scopes</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Expires</th>
                  <th scope="col" class="py-3.5 pl-3 pr-4 sm:pr-0">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white dark:divide-white/10 dark:bg-gray-900">
                <% @tokens.each do |token| %>
                  <tr>
                    <td class="whitespace-nowrap py-5 pl-4 pr-3 text-sm sm:pl-0">
                      <div class="flex items-center">
                        <div class="size-11 shrink-0">
                          <div class="size-11 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-semibold dark:bg-green-900/40 dark:text-green-300">TK</div>
                        </div>
                        <div class="ml-4">
                          <div class="font-medium text-gray-900 dark:text-white"><%= token.id %></div>
                          <div class="mt-1 text-gray-500 dark:text-gray-400">
                            Created <%= l(token.created_at, format: :short) rescue token.created_at.strftime("%b %d, %Y") %>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500 dark:text-gray-400">
                      <% if token.account %>
                        <div class="text-gray-900 dark:text-white"><%= token.account.name || 'Unnamed' %></div>
                        <div class="mt-1 text-gray-500 dark:text-gray-400">ID: <%= token.account.id %></div>
                      <% else %>
                        <span class="text-gray-400 dark:text-gray-500">No account</span>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-900 dark:text-white">
                      <%= token.client_id || 'Unknown' %>
                    </td>
                    <td class="px-3 py-5 text-sm text-gray-500 dark:text-gray-400">
                      <% if token.scopes.present? %>
                        <% token.scopes.split(' ').each do |scope| %>
                          <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10 dark:bg-gray-800 dark:text-gray-400 dark:ring-gray-500/20 mr-1 mb-1"><%= scope %></span>
                        <% end %>
                      <% else %>
                        <span class="text-gray-400 dark:text-gray-500">No scopes</span>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-900 dark:text-white">
                      <% if token.expires_at %>
                        <%= l(token.expires_at, format: :short) rescue token.expires_at.strftime("%b %d, %Y") %>
                      <% else %>
                        <span class="text-gray-400 dark:text-gray-500">Never</span>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap py-5 pl-3 pr-4 text-right text-sm font-medium sm:pr-0">
                      <%= button_to "Revoke", admin_token_path(token), method: :delete, data: { confirm: "Revoke this token?" }, class: "inline-flex items-center rounded-md bg-red-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 dark:bg-red-500 dark:hover:bg-red-400 dark:focus-visible:outline-red-500" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% else %>
      <div class="mt-6 rounded-md p-6 text-sm text-gray-600 ring-1 ring-inset ring-gray-200 dark:text-gray-300 dark:ring-white/10">
        No access tokens to display. Tokens are currently implemented as stateless JWTs.
      </div>
    <% end %>
  </div>
</div>
