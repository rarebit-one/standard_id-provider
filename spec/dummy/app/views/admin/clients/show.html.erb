<div class="space-y-8">
  <!-- Header -->
  <%= render partial: "shared/page_header", locals: {
        breadcrumbs: [
          { name: "Admin", href: "/admin" },
          { name: "Client Applications", href: "/admin/clients" },
          { name: @client.name }
        ],
        title: @client.name,
        tags: [
          (@client.active? ? "Active" : "Inactive"),
          ("#{@client.client_type.humanize} Client")
        ],
        actions: false
      } %>
  <div class="mt-4 flex md:ml-4 md:mt-0">
      <%= link_to edit_admin_client_path(@client), class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:ring-white/20 dark:hover:bg-white/20" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z" />
        </svg>
        Edit
      <% end %>
      <% if @client.confidential? %>
        <%= link_to rotate_secret_admin_client_path(@client), method: :patch,
              data: { confirm: "This will deactivate all existing secrets. Are you sure?" },
              class: "ml-3 inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z" clip-rule="evenodd" />
          </svg>
          Rotate Secret
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Flash Messages -->
  <% if flash[:secret_value] %>
    <div class="rounded-md bg-yellow-50 p-4 dark:bg-yellow-900/20">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-200">New Client Secret Generated</h3>
          <div class="mt-2 text-sm text-yellow-700 dark:text-yellow-300">
            <p>Copy this secret now - it won't be shown again:</p>
            <div class="mt-2 font-mono text-xs bg-yellow-100 dark:bg-yellow-800/30 p-2 rounded border">
              <%= flash[:secret_value] %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Client Details -->
  <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
    <div class="px-4 sm:px-0">
      <h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Client Information</h3>
      <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400">Basic details about this OAuth client application.</p>
    </div>

    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
      <div class="px-4 py-6 sm:p-8">
        <dl class="grid max-w-2xl grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
          <div class="sm:col-span-3">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Client ID</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300">
              <code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded text-xs font-mono"><%= @client.client_id %></code>
            </dd>
          </div>

          <div class="sm:col-span-3">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Client Type</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300"><%= @client.client_type.humanize %></dd>
          </div>

          <% if @client.description.present? %>
            <div class="sm:col-span-6">
              <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Description</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300"><%= @client.description %></dd>
            </div>
          <% end %>

          <div class="sm:col-span-6">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Redirect URIs</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300">
              <ul class="space-y-1">
                <% @client.redirect_uris_array.each do |uri| %>
                  <li><code class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded text-xs font-mono"><%= uri %></code></li>
                <% end %>
              </ul>
            </dd>
          </div>

          <div class="sm:col-span-2">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Scopes</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300">
              <div class="flex flex-wrap gap-1">
                <% @client.scopes_array.each do |scope| %>
                  <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10 dark:bg-gray-400/10 dark:text-gray-400 dark:ring-gray-400/20"><%= scope %></span>
                <% end %>
              </div>
            </dd>
          </div>

          <div class="sm:col-span-2">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Grant Types</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300">
              <div class="flex flex-wrap gap-1">
                <% @client.grant_types_array.each do |grant_type| %>
                  <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10 dark:bg-blue-400/10 dark:text-blue-400 dark:ring-blue-400/30"><%= grant_type %></span>
                <% end %>
              </div>
            </dd>
          </div>

          <div class="sm:col-span-2">
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Response Types</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300">
              <div class="flex flex-wrap gap-1">
                <% @client.response_types_array.each do |response_type| %>
                  <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:ring-green-400/20"><%= response_type %></span>
                <% end %>
              </div>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Client Secrets (for confidential clients) -->
  <% if @client.confidential? %>
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
      <div class="px-4 sm:px-0">
        <h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Client Secrets</h3>
        <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400">Active client secrets for authentication.</p>
      </div>

      <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
        <div class="px-4 py-6 sm:p-8">
          <% if @client_secrets.any? %>
            <ul role="list" class="divide-y divide-gray-100 dark:divide-gray-800">
              <% @client_secrets.each do |secret| %>
                <li class="flex items-center justify-between gap-x-6 py-5">
                  <div class="min-w-0">
                    <div class="flex items-start gap-x-3">
                      <p class="text-sm font-semibold leading-6 text-gray-900 dark:text-white"><%= secret.name %></p>
                      <p class="rounded-md whitespace-nowrap mt-0.5 px-1.5 py-0.5 text-xs font-medium ring-1 ring-inset text-green-700 bg-green-50 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:ring-green-400/20">Active</p>
                    </div>
                    <div class="mt-1 flex items-center gap-x-2 text-xs leading-5 text-gray-500 dark:text-gray-400">
                      <p>Created <%= time_ago_in_words(secret.created_at) %> ago</p>
                      <svg viewBox="0 0 2 2" class="h-0.5 w-0.5 fill-current">
                        <circle cx="1" cy="1" r="1" />
                      </svg>
                      <p>Client ID: <code class="text-xs"><%= secret.client_id %></code></p>
                    </div>
                  </div>
                  <div class="flex flex-none items-center gap-x-4">
                    <%= link_to "#",
                          data: { confirm: "Are you sure you want to revoke this secret?" },
                          class: "hidden rounded-md bg-white px-2.5 py-1.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:block dark:bg-white/10 dark:text-white dark:ring-white/20 dark:hover:bg-white/20" do %>
                      Revoke
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-6">
              <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159-.026-1.658.33L10.5 16.5l-1.902-1.902c-.848-.847-.858-2.2-.07-3.016a9.06 9.06 0 016.97-2.582zm-13.5 3a3 3 0 113 3 3 3 0 01-3-3zm3 3a3 3 0 003-3 3 3 0 00-3-3 3 3 0 00-3 3 3 3 0 003 3z" />
              </svg>
              <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">No active secrets</h3>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">This client doesn't have any active secrets.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <!-- PKCE Info for public clients -->
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
      <div class="px-4 sm:px-0">
        <h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">PKCE Authentication</h3>
        <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400">This public client uses PKCE for secure authentication.</p>
      </div>

      <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
        <div class="px-4 py-6 sm:p-8">
          <div class="rounded-md bg-blue-50 p-4 dark:bg-blue-900/20">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">PKCE Required</h3>
                <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
                  <p>This public client must use PKCE (Proof Key for Code Exchange) for authorization. No client secret is required.</p>
                  <% if @client.require_pkce? %>
                    <p class="mt-2">Supported challenge methods: <%= @client.code_challenge_methods_array.join(', ') %></p>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Token Lifetimes -->
  <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
    <div class="px-4 sm:px-0">
      <h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Token Configuration</h3>
      <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400">Token lifetime settings for this client.</p>
    </div>

    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
      <div class="px-4 py-6 sm:p-8">
        <dl class="grid max-w-2xl grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-3">
          <div>
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Access Token</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300"><%= distance_of_time_in_words(@client.access_token_lifetime) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Refresh Token</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300"><%= distance_of_time_in_words(@client.refresh_token_lifetime) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium leading-6 text-gray-900 dark:text-white">Authorization Code</dt>
            <dd class="mt-1 text-sm leading-6 text-gray-700 dark:text-gray-300"><%= distance_of_time_in_words(@client.authorization_code_lifetime) %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Danger Zone -->
  <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
    <div class="px-4 sm:px-0">
      <h3 class="text-base font-semibold leading-7 text-gray-900 dark:text-white">Danger Zone</h3>
      <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-400">Irreversible and destructive actions.</p>
    </div>

    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
      <div class="px-4 py-6 sm:p-8">
        <div class="flex items-center justify-between">
          <div>
            <h4 class="text-sm font-medium text-gray-900 dark:text-white">Delete this client</h4>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Once you delete a client, there is no going back. Please be certain.</p>
          </div>
          <%= link_to admin_client_path(@client), method: :delete,
                data: { confirm: "Are you sure you want to delete this client? This action cannot be undone." },
                class: "inline-flex items-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600" do %>
            Delete client
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
