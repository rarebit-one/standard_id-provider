<div class="px-4 sm:px-6 lg:px-8">
  <%= render partial: "shared/page_header", locals: {
        breadcrumbs: [
          { name: "Admin", href: "/admin" },
          { name: "Client Applications", href: "/admin/clients" },
          { name: "New" }
        ], 
        title: "New Client Application",
        tags: [],
        actions: false
      } %>

  <div class="space-y-10 divide-y divide-gray-900/10 dark:divide-white/10">
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
      <div class="px-4 sm:px-0"></div>

      <div class="bg-white shadow-sm ring-1 ring-gray-900/5 sm:rounded-xl md:col-span-2 dark:bg-gray-900 dark:ring-white/10">
        <%= form_with model: @client, url: admin_clients_path, local: true, class: "px-4 py-6 sm:p-8", scope: :client_application do |form| %>
          <div class="grid max-w-2xl grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
            <!-- Basic Information -->
            <div class="sm:col-span-4">
              <%= form.label :name, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_field :name, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "My Application" %>
              </div>
              <% if @client.errors[:name].any? %>
                <p class="mt-2 text-sm text-red-600 dark:text-red-400"><%= @client.errors[:name].first %></p>
              <% end %>
            </div>

            <div class="col-span-full">
              <%= form.label :description, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_area :description, rows: 3, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "A brief description of your application..." %>
              </div>
              <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-400">Write a few sentences about your application.</p>
            </div>

            <!-- Client Type -->
            <div class="sm:col-span-3">
              <%= form.label :client_type, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.select :client_type,
                      options_for_select([
                        ['Confidential (Server-side apps)', 'confidential'],
                        ['Public (Mobile/SPA apps)', 'public']
                      ], @client.client_type),
                      { prompt: 'Select client type' },
                      { class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:max-w-xs sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:focus:ring-indigo-500" } %>
              </div>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Confidential clients can securely store secrets. Public clients use PKCE.</p>
            </div>

            <!-- PKCE Settings -->
            <div class="sm:col-span-3">
              <div class="flex items-center">
                <%= form.check_box :require_pkce, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5 dark:focus:ring-indigo-500" %>
                <%= form.label :require_pkce, "Require PKCE", class: "ml-3 block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              </div>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Proof Key for Code Exchange adds security for public clients.</p>
            </div>

            <!-- Redirect URIs -->
            <div class="col-span-full">
              <%= form.label :redirect_uris, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_area :redirect_uris, rows: 3, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "https://myapp.com/callback\nhttps://myapp.com/auth/callback" %>
              </div>
              <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-400">Enter one redirect URI per line. These are the allowed callback URLs for your application.</p>
              <% if @client.errors[:redirect_uris].any? %>
                <p class="mt-2 text-sm text-red-600 dark:text-red-400"><%= @client.errors[:redirect_uris].first %></p>
              <% end %>
            </div>

            <!-- Scopes -->
            <div class="col-span-full">
              <%= form.label :scopes, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_field :scopes, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "read write profile", value: @client.scopes || "read" %>
              </div>
              <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-400">Space-separated list of OAuth scopes your application can request.</p>
            </div>

            <!-- Grant Types -->
            <div class="sm:col-span-3">
              <%= form.label :grant_types, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_field :grant_types, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "authorization_code refresh_token", value: @client.grant_types || "authorization_code" %>
              </div>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Space-separated OAuth grant types.</p>
            </div>

            <!-- Response Types -->
            <div class="sm:col-span-3">
              <%= form.label :response_types, class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.text_field :response_types, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", placeholder: "code token", value: @client.response_types || "code" %>
              </div>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Space-separated OAuth response types.</p>
            </div>

            <!-- Token Lifetimes -->
            <div class="sm:col-span-2">
              <%= form.label :access_token_lifetime, "Access Token Lifetime (seconds)", class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.number_field :access_token_lifetime, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", value: @client.access_token_lifetime || 3600 %>
              </div>
            </div>

            <div class="sm:col-span-2">
              <%= form.label :refresh_token_lifetime, "Refresh Token Lifetime (seconds)", class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.number_field :refresh_token_lifetime, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", value: @client.refresh_token_lifetime || 2592000 %>
              </div>
            </div>

            <div class="sm:col-span-2">
              <%= form.label :authorization_code_lifetime, "Auth Code Lifetime (seconds)", class: "block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= form.number_field :authorization_code_lifetime, class: "block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 dark:bg-white/5 dark:text-white dark:ring-white/10 dark:placeholder:text-gray-500 dark:focus:ring-indigo-500", value: @client.authorization_code_lifetime || 600 %>
              </div>
            </div>

            <!-- Advanced Settings -->
            <div class="col-span-full">
              <div class="flex items-center">
                <%= form.check_box :require_consent, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5 dark:focus:ring-indigo-500" %>
                <%= form.label :require_consent, "Require user consent", class: "ml-3 block text-sm font-medium leading-6 text-gray-900 dark:text-white" %>
              </div>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Always show consent screen to users, even for trusted applications.</p>
            </div>
          </div>

          <div class="mt-8 flex">
            <%= form.submit "Create Client", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400" %>
            <%= link_to "Cancel", admin_clients_path, class: "ml-3 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:ring-white/20 dark:hover:bg-white/20" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
